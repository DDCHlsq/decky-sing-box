{
  "name": "singbox-decky-plugin",
  "version": "1.0.0",
  "description": "Steam Deck Decky plugin for managing sing-box network proxy",
  "scripts": {
    "build": "webpack",
    "build:watch": "webpack --watch",
    "deploy": "scp -r dist/* deck@192.168.1.100:/home/deck/homebrew/plugins/singbox-manager/",
    "package": "tar -czvf singbox-manager.tar.gz dist/"
